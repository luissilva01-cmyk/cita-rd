rules_version = '2';

// Firebase Storage Security Rules para Ta' Pa' Ti
service firebase.storage {
  match /b/{bucket}/o {
    
    // ==============================
    // FUNCIONES AUXILIARES
    // ==============================
    
    // Verificar si el archivo es una imagen válida
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // Máximo 5MB
    }
    
    // Verificar si el archivo es audio válido
    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*') &&
             request.resource.size < 10 * 1024 * 1024; // Máximo 10MB
    }
    
    // Verificar si el archivo es video válido
    function isValidVideo() {
      return request.resource.contentType.matches('video/.*') &&
             request.resource.size < 50 * 1024 * 1024; // Máximo 50MB
    }
    
    // ==============================
    // FOTOS DE PERFIL
    // ==============================
    match /profile-photos/{userId}/{fileName} {
      // Lectura: Pública (cualquiera puede ver fotos de perfil)
      allow read: if true;
      
      // Escritura: Solo el dueño del perfil
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isValidImage();
      
      // Eliminación: Solo el dueño del perfil
      allow delete: if request.auth != null && 
                       request.auth.uid == userId;
    }
    
    // ==============================
    // FOTOS DE STORIES
    // ==============================
    match /stories/{userId}/{fileName} {
      // Lectura: Usuarios autenticados
      allow read: if request.auth != null;
      
      // Escritura: Solo el dueño de la story
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isValidImage();
      
      // Eliminación: Solo el dueño de la story
      allow delete: if request.auth != null && 
                       request.auth.uid == userId;
    }
    
    // ==============================
    // FOTOS DE CHAT
    // ==============================
    match /chat-photos/{chatId}/{fileName} {
      // Lectura: Usuarios autenticados (validación de participante en app)
      allow read: if request.auth != null;
      
      // Escritura: Usuarios autenticados
      allow write: if request.auth != null &&
                      isValidImage();
      
      // Eliminación: Usuarios autenticados
      allow delete: if request.auth != null;
    }
    
    // ==============================
    // MENSAJES DE VOZ
    // ==============================
    match /voice_messages/{chatId}/{fileName} {
      // Lectura: Usuarios autenticados
      allow read: if request.auth != null;
      
      // Escritura: Usuarios autenticados con audio válido
      allow write: if request.auth != null &&
                      isValidAudio();
      
      // Eliminación: Usuarios autenticados
      allow delete: if request.auth != null;
    }
    
    // ==============================
    // MENSAJES DE VIDEO
    // ==============================
    match /video_messages/{chatId}/{fileName} {
      // Lectura: Usuarios autenticados
      allow read: if request.auth != null;
      
      // Escritura: Usuarios autenticados con video válido
      allow write: if request.auth != null &&
                      isValidVideo();
      
      // Eliminación: Usuarios autenticados
      allow delete: if request.auth != null;
    }
    
    // ==============================
    // FOTOS DE VERIFICACIÓN
    // ==============================
    match /verification-photos/{userId}/{fileName} {
      // Lectura: Solo admins y el propio usuario
      allow read: if request.auth != null && 
                     request.auth.uid == userId;
      
      // Escritura: Solo el dueño
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      isValidImage();
      
      // Eliminación: Solo el dueño
      allow delete: if request.auth != null && 
                       request.auth.uid == userId;
    }
    
    // ==============================
    // DENEGAR TODO LO DEMÁS
    // ==============================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
