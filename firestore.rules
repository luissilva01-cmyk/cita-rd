rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==============================
    // FUNCIONES AUXILIARES
    // ==============================
    
    // Verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verificar si el usuario es el dueño del recurso
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Verificar si el usuario es administrador
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Verificar si el usuario es participante de un chat
    function isChatParticipant(chatId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    
    // Validar datos de perfil
    function isValidProfile() {
      let data = request.resource.data;
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.age is int && data.age >= 18 && data.age <= 100 &&
             data.bio is string && data.bio.size() <= 500 &&
             data.location is string && data.location.size() > 0 &&
             data.interests is list && data.interests.size() <= 20 &&
             data.images is list && 
             data.images.size() >= 1 &&  // ✅ MÍNIMO 1 FOTO OBLIGATORIA
             data.images.size() <= 6;    // ✅ MÁXIMO 6 FOTOS
    }
    
    // ==============================
    // COLECCIÓN: users (perfiles de usuario)
    // ==============================
    match /users/{userId} {
      // Leer: Solo usuarios autenticados
      allow read: if isAuthenticated();
      
      // Crear: Solo el propio usuario con datos válidos
      allow create: if isOwner(userId) && isValidProfile();
      
      // Escribir (update, set, merge): Solo el propio usuario
      // Simplificado para permitir actualizaciones parciales
      allow write: if isOwner(userId);
      
      // Eliminar: Solo el propio usuario
      allow delete: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: perfiles (alias de users)
    // ==============================
    match /perfiles/{userId} {
      // Leer: Solo usuarios autenticados
      allow read: if isAuthenticated();
      
      // Crear: Solo el propio usuario con datos válidos
      allow create: if isOwner(userId) && isValidProfile();
      
      // Escribir (update, set, merge): Solo el propio usuario
      // Simplificado para permitir actualizaciones parciales
      allow write: if isOwner(userId);
      
      // Eliminar: Solo el propio usuario
      allow delete: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: chats
    // ==============================
    match /chats/{chatId} {
      // Leer: Solo participantes del chat
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.participants;
      
      // Escribir (create, update, set): Simplificado
      // Solo verificar que el usuario esté autenticado y sea participante
      allow write: if isAuthenticated();
      
      // Eliminar: No permitido (los chats no se eliminan, solo se archivan)
      allow delete: if false;
      
      // Subcolección: messages
      match /messages/{messageId} {
        // Leer: Solo participantes del chat
        allow read: if isChatParticipant(chatId);
        
        // Crear: Solo participantes del chat
        allow create: if isChatParticipant(chatId);
        
        // Actualizar: Participantes del chat pueden actualizar
        allow update: if isChatParticipant(chatId);
        
        // Eliminar: No permitido (usamos soft delete)
        allow delete: if false;
      }
      
      // Subcolección: typingStatus
      match /typingStatus/{userId} {
        // Leer: Solo participantes del chat
        allow read: if isChatParticipant(chatId);
        
        // Escribir: Solo el propio usuario
        allow write: if isChatParticipant(chatId) && isOwner(userId);
      }
    }
    
    // ==============================
    // COLECCIÓN: matches
    // ==============================
    match /matches/{matchId} {
      // Leer: Solo si el usuario es uno de los participantes del match
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.users;
      
      // Crear: Usuarios autenticados pueden crear matches
      allow create: if isAuthenticated() && 
                       request.auth.uid in request.resource.data.users &&
                       request.resource.data.users is list &&
                       request.resource.data.users.size() == 2;
      
      // Actualizar: Solo participantes del match
      allow update: if isAuthenticated() && 
                       request.auth.uid in resource.data.users;
      
      // Eliminar: Solo participantes del match
      allow delete: if isAuthenticated() && 
                      request.auth.uid in resource.data.users;
    }
    
    // ==============================
    // COLECCIÓN: likes
    // ==============================
    match /likes/{likeId} {
      // Leer: Usuarios autenticados pueden ver likes
      allow read: if isAuthenticated();
      
      // Crear: Solo el usuario puede crear sus propios likes
      // Validar que fromUserId coincida con el usuario autenticado
      allow create: if isAuthenticated() && 
                       request.resource.data.fromUserId == request.auth.uid &&
                       request.resource.data.toUserId is string &&
                       request.resource.data.toUserId != request.auth.uid; // No puede gustarse a sí mismo
      
      // Actualizar: No permitido (likes son inmutables)
      allow update: if false;
      
      // Eliminar: El usuario que creó el like O el usuario que lo recibió
      // Esto permite eliminar likes después de match o pass
      allow delete: if isAuthenticated() && 
                      (resource.data.fromUserId == request.auth.uid || 
                       resource.data.toUserId == request.auth.uid);
    }
    
    // ==============================
    // COLECCIÓN: stories
    // ==============================
    match /stories/{storyId} {
      // Leer: Usuarios autenticados (privacidad se maneja en código)
      allow read: if isAuthenticated();
      
      // Crear: Usuario autenticado con userId correcto
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.type in ['image', 'text'] &&
                       request.resource.data.content is string &&
                       request.resource.data.content.size() > 0;
      
      // Actualizar: Solo el dueño (para viewedBy)
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Eliminar: Solo el dueño
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // ==============================
    // COLECCIÓN: presence
    // ==============================
    match /presence/{userId} {
      // Leer: Usuarios autenticados
      allow read: if isAuthenticated();
      
      // Escribir: Solo el propio usuario
      allow write: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: privacySettings
    // ==============================
    match /privacySettings/{userId} {
      // Leer: Solo el propio usuario
      allow read: if isOwner(userId);
      
      // Escribir: Solo el propio usuario
      allow write: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: verifications
    // ==============================
    match /verifications/{userId} {
      // Leer: Usuarios autenticados (para ver badges)
      allow read: if isAuthenticated();
      
      // Escribir: Solo el propio usuario
      allow write: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: fcmTokens
    // ==============================
    match /fcmTokens/{userId} {
      // Leer: Solo el propio usuario
      allow read: if isOwner(userId);
      
      // Escribir: Solo el propio usuario
      allow write: if isOwner(userId);
    }
    
    // ==============================
    // COLECCIÓN: reports (reportes de usuarios)
    // ==============================
    match /reports/{reportId} {
      // Leer: Solo admins
      allow read: if isAdmin();
      
      // Crear: Usuario autenticado puede reportar
      allow create: if isAuthenticated() && 
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.reportedUserId is string &&
                       request.resource.data.reportedUserId != request.auth.uid && // No puede reportarse a sí mismo
                       request.resource.data.category in ['fake_profile', 'inappropriate_content', 'harassment', 'spam', 'underage', 'other'] &&
                       request.resource.data.description is string &&
                       request.resource.data.description.size() <= 500 && // Descripción opcional, máximo 500 caracteres
                       request.resource.data.timestamp is timestamp &&
                       request.resource.data.status == 'pending';
      
      // Actualizar: Solo admins pueden actualizar reportes
      allow update: if isAdmin();
      
      // Eliminar: Solo admins
      allow delete: if isAdmin();
    }
    
    // ==============================
    // COLECCIÓN: blocks (usuarios bloqueados)
    // ==============================
    match /blocks/{blockId} {
      // Leer: Solo el usuario que bloqueó
      allow read: if isAuthenticated() && 
                     resource.data.blockerId == request.auth.uid;
      
      // Crear: Usuario autenticado puede bloquear
      allow create: if isAuthenticated() && 
                       request.resource.data.blockerId == request.auth.uid &&
                       request.resource.data.blockedUserId is string &&
                       request.resource.data.blockedUserId != request.auth.uid; // No puede bloquearse a sí mismo
      
      // Actualizar: No permitido (blocks son inmutables)
      allow update: if false;
      
      // Eliminar: Solo el usuario que bloqueó
      allow delete: if isAuthenticated() && 
                      resource.data.blockerId == request.auth.uid;
    }
    
    // ==============================
    // COLECCIÓN: notifications
    // ==============================
    match /notifications/{notificationId} {
      // Leer: Solo el destinatario de la notificación
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Crear: Sistema/Cloud Functions (usuarios no pueden crear notificaciones)
      allow create: if false;
      
      // Actualizar: Solo el destinatario (para marcar como leída)
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Eliminar: Solo el destinatario
      allow delete: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid;
    }
    
    // ==============================
    // COLECCIÓN: analytics (eventos de analytics)
    // ==============================
    match /analytics/{eventId} {
      // Leer: Solo admins
      allow read: if false;
      
      // Crear: Usuario autenticado puede crear eventos
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Actualizar/Eliminar: No permitido
      allow update, delete: if false;
    }
    
    // ==============================
    // COLECCIÓN: superLikes
    // ==============================
    match /superLikes/{superLikeId} {
      // Leer: Usuarios autenticados
      allow read: if isAuthenticated();
      
      // Crear: Solo el usuario puede crear sus propios super likes
      allow create: if isAuthenticated() && 
                       request.resource.data.fromUserId == request.auth.uid &&
                       request.resource.data.toUserId is string &&
                       request.resource.data.toUserId != request.auth.uid;
      
      // Actualizar: No permitido (super likes son inmutables)
      allow update: if false;
      
      // Eliminar: Solo el usuario que creó el super like
      allow delete: if isAuthenticated() && 
                      resource.data.fromUserId == request.auth.uid;
    }
    
    // ==============================
    // DENEGAR TODO LO DEMÁS
    // ==============================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}